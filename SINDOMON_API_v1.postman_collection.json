{
  "info": {
    "name": "SINDOMON API v1",
    "description": "Complete API Collection for SINDOMON (Sistem Informasi Operasi dan Monitoring Polri). Covers all Blueprint Groups 1–7: Auth, Role, Profile, Master Data, Polda, SDM, Pengaduan, Knowledge Hub, Kamtibmas, DMS, and Logistik.\n\nBase URL: {{base_url}} (default: http://localhost:8080)\nAuth: {{token}} is auto-set by Login request's Test script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "sindomon-architect"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.jwt_token) {",
                  "    pm.environment.set('token', jsonData.data.jwt_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newoperator\",\n  \"password\": \"pass12345\",\n  \"roles_id\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/insert",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "insert"]
            }
          }
        },
        {
          "name": "GET All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user"]
            }
          }
        }
      ]
    },
